---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body
		class="min-h-screen bg-[radial-gradient(ellipse_at_top_right,_#7C3AED33_0%,_transparent_60%)] bg-white"
	>
		<header class="w-full flex items-center justify-center p-4" id="nav">
			<nav>
				<ul
					class="flex flex-row items-center gap-8 text-2xl font-light text-gray-900"
				>
					<li class="group flex flex-col items-center gap-1">
						<a href="/">Home</a>
						<div
							class="h-1 w-full border-2 border-violet-500 rounded-full animate-expand -translate-x-100 opacity-0 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 ease-in-out"
						>
						</div>
					</li>
					<li class="group flex flex-col items-center gap-1">
						<a href="/work">Current Work</a>
						<div
							class="h-1 w-full border-2 border-violet-500 rounded-full animate-expand -translate-x-100 opacity-0 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 ease-in-out"
						>
						</div>
					</li>
					<li class="relative group flex flex-col items-center gap-1">
						<button class="flex items-center gap-1">
							Photography
							<svg
								class="w-4 h-4 text-gray-400 transition-transform duration-200 group-hover:rotate-180"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
								stroke-width="2"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div
							class="h-1 w-full border-2 border-violet-500 rounded-full opacity-0 group-hover:opacity-100 transition-all duration-300 ease-in-out"
						>
						</div>
						<!-- Dropdown -->
						<ul
							class="absolute top-full left-1/2 -translate-x-1/2 pt-3 w-52 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all duration-200 translate-y-1 group-hover:translate-y-0 z-50"
						>
							<div
								class="bg-white rounded-2xl border border-gray-100 shadow-xl overflow-hidden"
							>
								<li>
									<a
										href="/photography/real-estate"
										class="flex items-center gap-3 px-5 py-3.5 text-sm font-light text-gray-700 hover:bg-gray-50 hover:text-violet-600 transition-colors duration-150 border-b border-gray-50"
									>
										<span class="w-1.5 h-1.5 rounded-full bg-gray-300 shrink-0"
										></span>
										Real Estate
									</a>
								</li>
								<li>
									<a
										href="/photography/concert"
										class="flex items-center gap-3 px-5 py-3.5 text-sm font-light text-gray-700 hover:bg-gray-50 hover:text-violet-600 transition-colors duration-150 border-b border-gray-50"
									>
										<span class="w-1.5 h-1.5 rounded-full bg-gray-300 shrink-0"
										></span>
										Concert & Music
									</a>
								</li>
								<li>
									<a
										href="/photography/brand-media"
										class="flex items-center gap-3 px-5 py-3.5 text-sm font-light text-gray-700 hover:bg-gray-50 hover:text-violet-600 transition-colors duration-150 border-b border-gray-50"
									>
										<span class="w-1.5 h-1.5 rounded-full bg-gray-300 shrink-0"
										></span>
										Brand Media
									</a>
								</li>
							</div>
						</ul>
					</li>
					<li class="group flex flex-col items-center gap-1">
						<a href="/about">About</a>
						<div
							class="h-1 w-full border-2 border-violet-500 rounded-full animate-expand -translate-x-100 opacity-0 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 ease-in-out"
						>
						</div>
					</li>
					<li class="group flex flex-col items-center gap-1">
						<a href="/projects">Upcoming Builds</a>
						<div
							class="h-1 w-full border-2 border-violet-500 rounded-full animate-expand -translate-x-100 opacity-0 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 ease-in-out"
						>
						</div>
					</li>
					<li class="group flex flex-col items-center gap-1">
						<a href="/contact">Contact</a>
						<div
							class="h-1 w-full border-2 border-violet-500 rounded-full animate-expand -translate-x-100 opacity-0 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 ease-in-out"
						>
						</div>
					</li>
				</ul>
			</nav>
		</header>
		<slot />

		<Footer />
	</body>
</html>
