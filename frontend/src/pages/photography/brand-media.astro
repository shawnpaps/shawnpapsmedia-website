---
import BaseLayout from "../../layouts/BaseLayout.astro";

const CMS_BASE = import.meta.env.PUBLIC_CMS_BASE ?? "http://localhost:3000";

let photos: {
	image: { url: string; alt: string };
	caption?: string;
	featured?: boolean;
}[] = [];

try {
	const res = await fetch(
		`${CMS_BASE}/api/category-galleries/2?depth=2&draft=false&locale=undefined&trash=false`,
	);
	const data = await res.json();
	photos = data?.photos ?? [];
} catch (e) {
	console.error("Failed to fetch brand media gallery:", e);
}

const featuredPhoto = photos.find((p) => p.featured) ?? photos[0];
const gridPhotos = photos.filter((p) => p !== featuredPhoto);
---

<BaseLayout>
	<div class="bg-white text-gray-900 min-h-screen">
		<!-- Hero -->
		<section
			class="relative flex flex-col justify-end min-h-[90vh] px-20 py-24 overflow-hidden bg-gray-900"
		>
			<div
				class="absolute inset-0 bg-[linear-gradient(to_bottom,_transparent_30%,_#111111_100%)] z-10"
			>
			</div>
			<div class="absolute inset-0">
				{
					featuredPhoto && (
						<img
							src={`${CMS_BASE}${featuredPhoto.image.url}`}
							alt={featuredPhoto.image.alt ?? ""}
							class="w-full h-full object-cover opacity-40"
						/>
					)
				}
			</div>

			<!-- Large background type -->
			<span
				class="absolute top-16 right-16 text-[200px] font-black text-white/5 leading-none select-none z-10"
			>
				BRAND
			</span>

			<div class="relative z-20 max-w-3xl">
				<span
					class="text-xs font-medium text-amber-400 uppercase tracking-widest mb-4 block"
				>
					Photography — Brand Media
				</span>
				<h1
					class="text-7xl font-black leading-none text-white mb-6 uppercase"
				>
					Make them<br />stop scrolling.
				</h1>
				<p
					class="text-xl font-light text-gray-400 max-w-xl leading-relaxed"
				>
					Bold, intentional brand photography that tells your story in
					a single frame — built for campaigns, content, and the
					moments that define how people see you.
				</p>
			</div>
		</section>

		<!-- Intro -->
		<section
			class="px-20 py-24 flex flex-row items-start justify-between gap-20 border-b border-gray-100"
		>
			<div class="max-w-sm shrink-0">
				<h2
					class="text-4xl font-black text-gray-900 leading-tight uppercase"
				>
					Image is<br />everything.
				</h2>
			</div>
			<div class="flex flex-col gap-6 max-w-xl">
				<p class="text-lg font-light text-gray-500 leading-relaxed">
					Your brand deserves visuals that match its ambition. I work
					with founders, creative directors, and marketing teams to
					produce photography that's campaign-ready from the first
					shot — no endless revisions, no generic stock-photo energy.
				</p>
				<p class="text-lg font-light text-gray-500 leading-relaxed">
					From product launches to executive portraits to full
					campaign shoots, every frame is built around your brand's
					identity and the story you're trying to tell.
				</p>
			</div>
		</section>

		<!-- Photo grid -->
		<section class="px-20 py-24 bg-gray-950">
			{
				gridPhotos.length > 0 ? (
					<div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
						{gridPhotos.map((photo) => (
							<div class="break-inside-avoid overflow-hidden bg-[#1a1a1a]">
								<img
									src={`${CMS_BASE}${photo.image.url}`}
									alt={photo.image.alt ?? ""}
									class="w-full h-auto object-cover"
								/>
								{photo.caption && (
									<p class="px-4 py-2 text-xs text-gray-500 font-light">
										{photo.caption}
									</p>
								)}
							</div>
						))}
					</div>
				) : (
					<p class="text-gray-600 text-sm font-light">
						No photos yet.
					</p>
				)
			}
		</section>

		<!-- Services -->
		<section class="px-20 py-24 border-t border-gray-100">
			<div class="flex flex-col gap-12">
				<div class="flex flex-row items-end justify-between">
					<div class="flex flex-col gap-2">
						<span
							class="text-xs font-medium text-amber-500 uppercase tracking-widest"
						>
							What I deliver
						</span>
						<h2 class="text-4xl font-black text-gray-900 uppercase">
							Services
						</h2>
					</div>
				</div>
				<div
					class="grid grid-cols-1 md:grid-cols-3 gap-0 border-t border-l border-gray-100"
				>
					{
						[
							{
								title: "Campaign Shoots",
								desc: "Full creative concept, production, and photography for seasonal or product campaigns.",
							},
							{
								title: "Executive Portraits",
								desc: "Confident, editorial headshots and portraits for founders, teams, and press kits.",
							},
							{
								title: "Product Photography",
								desc: "Clean and editorial product imagery built for e-commerce, ads, and print.",
							},
							{
								title: "Content Creation",
								desc: "High-volume social content shoots — batched, efficient, and always on-brand.",
							},
							{
								title: "Creative Direction",
								desc: "Moodboards, shot lists, and full production planning for brands that need the full package.",
							},
							{
								title: "Brand Identity Shoots",
								desc: "Foundational imagery that defines how a brand looks and feels across all touchpoints.",
							},
						].map((s) => (
							<div class="flex flex-col gap-3 p-8 border-b border-r border-gray-100">
								<h3 class="text-base font-bold text-gray-900 uppercase tracking-tight">
									{s.title}
								</h3>
								<p class="text-sm font-light text-gray-500 leading-relaxed">
									{s.desc}
								</p>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section
			class="px-20 py-32 bg-gray-950 flex flex-col items-center text-center gap-6"
		>
			<span
				class="text-xs font-medium text-amber-400 uppercase tracking-widest"
			>
				Let's work together
			</span>
			<h2
				class="text-5xl font-black text-white uppercase max-w-xl leading-tight"
			>
				Ready to build something iconic?
			</h2>
			<p
				class="text-lg font-light text-gray-500 max-w-md leading-relaxed"
			>
				Tell me about your brand, your campaign, and what you're trying
				to say. Let's make it impossible to ignore.
			</p>
			<a
				href="/contact"
				class="mt-4 px-8 py-4 rounded-none bg-amber-400 text-gray-900 text-sm font-bold uppercase tracking-widest hover:bg-amber-300 transition-colors duration-200"
			>
				Get in touch
			</a>
		</section>
	</div>
</BaseLayout>
