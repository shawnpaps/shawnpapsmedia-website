---
import BaseLayout from "../../layouts/BaseLayout.astro";

const CMS_BASE = import.meta.env.PUBLIC_CMS_BASE ?? "http://localhost:3000";

let photos: {
	image: { url: string; alt: string };
	caption?: string;
	featured?: boolean;
}[] = [];

try {
	const res = await fetch(
		`${CMS_BASE}/api/category-galleries/1?depth=2&draft=false&locale=undefined&trash=false`,
	);
	const data = await res.json();
	photos = data?.photos ?? [];
} catch (e) {
	console.error("Failed to fetch concert gallery:", e);
}

const featuredPhoto = photos.find((p) => p.featured) ?? photos[0];
const gridPhotos = photos.filter((p) => p !== featuredPhoto);
---

<BaseLayout>
	<div class="bg-[#0a0a0a] text-white min-h-screen">
		<!-- Hero -->
		<section
			class="relative flex flex-col justify-end min-h-[90vh] px-20 py-24 overflow-hidden"
		>
			<div
				class="absolute inset-0 bg-[linear-gradient(to_bottom,_transparent_30%,_#0a0a0a_100%)] z-10"
			>
			</div>
			<div class="absolute inset-0 bg-[#1a1a1a]">
				{
					featuredPhoto && (
						<img
							src={`${CMS_BASE}${featuredPhoto.image.url}`}
							alt={featuredPhoto.image.alt ?? ""}
							class="w-full h-full object-cover object-top opacity-50"
						/>
					)
				}
			</div>

			<div class="relative z-20 max-w-3xl">
				<span
					class="text-xs font-medium text-violet-400 uppercase tracking-widest mb-4 block"
				>
					Music — Photo & Video
				</span>
				<h1 class="text-7xl font-semibold leading-none text-white mb-6">
					The moment<br />before the roar.
				</h1>
				<p
					class="text-xl font-light text-gray-400 max-w-xl leading-relaxed"
				>
					Cinematic photo and video for artists, labels, and venues.
					The kind of content that makes people wish they were there.
				</p>
			</div>
		</section>

		<!-- Intro -->
		<section
			class="px-20 py-24 flex flex-row items-start justify-between gap-20 border-b border-white/10"
		>
			<div class="max-w-sm shrink-0">
				<h2 class="text-4xl font-semibold text-white leading-tight">
					Fast. Raw.<br />Real.
				</h2>
			</div>
			<div class="flex flex-col gap-6 max-w-xl">
				<p class="text-lg font-light text-gray-400 leading-relaxed">
					Concert photography lives and dies in the first three songs.
					We work fast, move with the music, and find the frames that
					tell the story of a night — from the pit to the back of the
					room.
				</p>
				<p class="text-lg font-light text-gray-400 leading-relaxed">
					Whether it's a stadium tour or an underground venue with no
					stage lighting, we know how to find the shot in the dark.
				</p>
			</div>
		</section>

		<!-- Photo grid -->
		<section class="px-20 py-24">
			{
				gridPhotos.length > 0 ? (
					<div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
						{gridPhotos.map((photo) => (
							<div class="break-inside-avoid rounded-xl overflow-hidden bg-[#1a1a1a]">
								<img
									src={`${CMS_BASE}${photo.image.url}`}
									alt={photo.image.alt ?? ""}
									class="w-full h-auto object-cover"
								/>
								{photo.caption && (
									<p class="px-4 py-2 text-xs text-gray-500 font-light">
										{photo.caption}
									</p>
								)}
							</div>
						))}
					</div>
				) : (
					<p class="text-gray-600 text-sm font-light">
						No photos yet.
					</p>
				)
			}
		</section>

		<!-- Services -->
		<section class="px-20 py-24 bg-[#0f0f0f] border-t border-white/10">
			<div class="flex flex-col gap-12">
				<div class="flex flex-col gap-2">
					<span
						class="text-xs font-medium text-violet-400 uppercase tracking-widest"
						>What we cover</span
					>
					<h2 class="text-4xl font-semibold text-white">Services</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					{
						[
							{
								title: "Live Concerts",
								desc: "Pit access, full-show coverage, and editorial selects for press or promotion.",
							},
							{
								title: "Festival Coverage",
								desc: "Multi-stage, multi-day photo and video coverage for festivals of any size.",
							},
							{
								title: "Music Videos",
								desc: "Concept, production, and post — music videos that match the artist's vision and sound.",
							},
							{
								title: "Press & Promo",
								desc: "Artist portraits and promotional imagery for press kits, social, and album campaigns.",
							},
							{
								title: "Tour Documentation",
								desc: "Behind-the-scenes and on-stage photo/video documentation across a full tour run.",
							},
							{
								title: "Licensing",
								desc: "Images and video licensed for editorial, streaming platforms, and commercial use.",
							},
						].map((s) => (
							<div class="flex flex-col gap-3 p-8 bg-white/5 rounded-2xl border border-white/10">
								<h3 class="text-base font-semibold text-white">
									{s.title}
								</h3>
								<p class="text-sm font-light text-gray-500 leading-relaxed">
									{s.desc}
								</p>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section
			class="px-20 py-32 flex flex-col items-center text-center gap-6 border-t border-white/10"
		>
			<span
				class="text-xs font-medium text-violet-400 uppercase tracking-widest"
				>Let's talk</span
			>
			<h2
				class="text-5xl font-semibold text-white max-w-xl leading-tight"
			>
				Got a show coming up?
			</h2>
			<p
				class="text-lg font-light text-gray-500 max-w-md leading-relaxed"
			>
				Let's talk dates, access, and what you need — whether it's
				press shots, a music video, or full coverage.
			</p>
			<a
				href="/contact"
				class="mt-4 px-8 py-4 rounded-full bg-violet-600 text-white text-sm font-medium hover:bg-violet-700 transition-colors duration-200"
			>
				Let's talk
			</a>
		</section>
	</div>
</BaseLayout>
