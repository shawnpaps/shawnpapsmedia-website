---
import BaseLayout from "../layouts/BaseLayout.astro";

const services = [
	{
		label: "Photography",
		items: [
			"Brand & commercial",
			"Lifestyle & editorial",
			"Real estate & property",
			"Concert & music",
		],
	},
	{
		label: "Video & Content",
		items: [
			"Brand video",
			"Property walkthroughs",
			"Short-form content",
			"Social deliverables",
		],
	},
	{
		label: "Web & Digital",
		items: [
			"Media-driven websites",
			"Shopify & e-commerce",
			"Platform integrations",
			"Full-stack development",
		],
	},
];

const clients = [
	{
		type: "Creative Brands",
		desc: "Barbers, coffee shops, apparel, makers, and B2C brands with a strong visual identity.",
	},
	{
		type: "Real Estate",
		desc: "Agents and teams with active listings who need consistent, professional photography and brand content.",
	},
	{
		type: "Music & Artists",
		desc: "Artists, bands, gear companies, and music industry businesses that need visuals with actual energy.",
	},
	{
		type: "Creative Startups",
		desc: "Founders who want one partner to handle visuals and digital infrastructure — no juggling vendors.",
	},
];
---

<BaseLayout>
	<main class="flex flex-col min-h-screen px-20 py-16 gap-28">
		<!-- Hero -->
		<section
			class="flex flex-row items-center justify-between gap-16 w-full"
		>
			<div class="flex flex-col gap-6 max-w-2xl">
				<span
					class="text-xs font-medium text-violet-600 uppercase tracking-widest"
				>
					Shawn Paps Media — Tampa, FL
				</span>
				<h1 class="text-6xl font-semibold text-gray-900 leading-tight">
					One studio.<br />Full picture.
				</h1>
				<p class="text-xl font-light text-gray-500 leading-relaxed">
					Shawn Paps Media is a Tampa-based photography and content
					studio serving creative brands, lifestyle businesses, and
					real estate professionals.
				</p>
				<p class="text-xl font-light text-gray-500 leading-relaxed">
					The studio is led by a photographer with 7+ years of
					software engineering experience — which means you get a
					creative partner who can shoot your brand, build your
					website, set up your store, and integrate the tools your
					business runs on. No handoffs. No friction.
				</p>
				<div class="flex flex-row items-center gap-4 mt-2">
					<a
						href="/contact"
						class="px-6 py-3 rounded-full bg-violet-600 text-white text-sm font-medium hover:bg-violet-700 transition-colors duration-200"
					>
						Start a project
					</a>
					<a
						href="/work"
						class="px-6 py-3 rounded-full border border-gray-200 text-gray-700 text-sm font-medium hover:border-violet-300 hover:text-violet-600 transition-colors duration-200"
					>
						See the work
					</a>
				</div>
			</div>

			<div
				class="shrink-0 w-80 h-80 rounded-2xl overflow-hidden shadow-lg"
			>
				<img
					src={`${import.meta.env.PUBLIC_CMS_BASE ?? "http://localhost:3000"}/api/media/file/shawn_computer`}
					alt="Shawn Paps Media"
					class="w-full h-full object-cover"
				/>
			</div>
		</section>

		<!-- The Edge -->
		<section
			class="flex flex-row items-start gap-20 border-t border-gray-100 pt-28"
		>
			<div class="max-w-sm shrink-0 flex flex-col gap-3">
				<span
					class="text-xs font-medium text-violet-600 uppercase tracking-widest"
				>
					The difference
				</span>
				<h2 class="text-4xl font-semibold text-gray-900 leading-tight">
					The technical edge no other photographer can offer.
				</h2>
			</div>
			<div class="flex flex-col gap-6 max-w-xl pt-1">
				<p class="text-lg font-light text-gray-500 leading-relaxed">
					Most businesses have to hire a photographer, a videographer,
					a web developer, and a Shopify consultant separately — and
					then hope they all communicate. This studio does all of it
					under one roof, with one creative vision.
				</p>
				<p class="text-lg font-light text-gray-500 leading-relaxed">
					The result is faster delivery, tighter execution, and a
					brand that actually looks like itself across every
					touchpoint — from the hero image on your homepage to the
					product photos in your store.
				</p>
				<!-- Signature offer callout -->
				<div
					class="mt-4 p-6 rounded-2xl border border-violet-100 bg-violet-50"
				>
					<p
						class="text-xs font-semibold text-violet-600 uppercase tracking-widest mb-2"
					>
						Signature Offer
					</p>
					<h3 class="text-xl font-semibold text-gray-900 mb-2">
						The Rollout
					</h3>
					<p class="text-sm font-light text-gray-600 leading-relaxed">
						A complete digital brand launch combining original
						photography with a full website redesign and strategy.
						Built for creative brands ready to look like they
						belong.
					</p>
				</div>
			</div>
		</section>

		<!-- Services -->
		<section class="flex flex-col gap-10">
			<div class="flex flex-col gap-2">
				<span
					class="text-xs font-medium text-violet-600 uppercase tracking-widest"
				>
					Services
				</span>
				<h2 class="text-4xl font-semibold text-gray-900">
					What we do.
				</h2>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				{
					services.map((group) => (
						<div class="flex flex-col gap-4 p-8 rounded-2xl border border-gray-100 bg-white/60 backdrop-blur-sm shadow-sm">
							<p class="text-xs font-semibold text-violet-600 uppercase tracking-widest">
								{group.label}
							</p>
							<ul class="flex flex-col gap-2">
								{group.items.map((item) => (
									<li class="flex items-center gap-2 text-gray-700 text-base font-light">
										<span class="w-1 h-1 rounded-full bg-violet-400 shrink-0" />
										{item}
									</li>
								))}
							</ul>
						</div>
					))
				}
			</div>
		</section>

		<!-- Who we serve -->
		<section class="flex flex-col gap-10">
			<div class="flex flex-col gap-2">
				<span
					class="text-xs font-medium text-violet-600 uppercase tracking-widest"
				>
					Who we work with
				</span>
				<h2 class="text-4xl font-semibold text-gray-900">
					Built for brands that care about craft.
				</h2>
			</div>

			<div class="flex flex-col">
				{
					clients.map((client, i) => (
						<div
							class={`flex flex-row gap-12 py-10 ${i !== clients.length - 1 ? "border-b border-gray-100" : ""}`}
						>
							<h3 class="text-lg font-semibold text-gray-900 w-48 shrink-0 pt-0.5">
								{client.type}
							</h3>
							<p class="text-base font-light text-gray-500 leading-relaxed max-w-xl">
								{client.desc}
							</p>
						</div>
					))
				}
			</div>

			<p class="text-base font-light text-gray-400 italic max-w-xl">
				Ideal client: someone who cares about craft and wants their
				brand to look as good as their product actually is.
			</p>
		</section>

		<!-- Location -->
		<section
			class="flex flex-row items-center gap-6 p-8 rounded-2xl border border-gray-100 bg-white/60 backdrop-blur-sm shadow-sm w-fit"
		>
			<div class="flex items-center gap-2">
				<div
					class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse shrink-0"
				>
				</div>
				<p class="text-sm font-medium text-gray-700">
					Based in Tampa, FL
				</p>
			</div>
			<div class="w-px h-4 bg-gray-200"></div>
			<p class="text-sm font-light text-gray-500">
				Available throughout the Tampa Bay area
			</p>
			<div class="w-px h-4 bg-gray-200"></div>
			<p class="text-sm font-light text-gray-500">
				Remote-friendly for web & digital projects
			</p>
		</section>

		<!-- CTA -->
		<section class="flex flex-col items-center text-center gap-6 py-20">
			<span
				class="text-xs font-medium text-violet-600 uppercase tracking-widest"
			>
				Let's build something
			</span>
			<h2
				class="text-5xl font-semibold text-gray-900 max-w-xl leading-tight"
			>
				Ready to look like you belong?
			</h2>
			<p
				class="text-xl font-light text-gray-500 max-w-lg leading-relaxed"
			>
				Reach out through the contact form or find us on Instagram
				<a
					href="https://instagram.com/shawnpapsmedia"
					target="_blank"
					rel="noopener noreferrer"
					class="text-violet-600 hover:underline">@shawnpapsmedia</a
				>. Tell us about your project and let's go from there.
			</p>
			<div class="flex flex-row items-center gap-4 mt-2">
				<a
					href="/contact"
					class="px-8 py-4 rounded-full bg-violet-600 text-white text-base font-medium hover:bg-violet-700 transition-colors duration-200"
				>
					Start a project
				</a>
				<a
					href="https://instagram.com/shawnpapsmedia"
					target="_blank"
					rel="noopener noreferrer"
					class="px-8 py-4 rounded-full border border-gray-200 text-gray-700 text-base font-medium hover:border-violet-300 hover:text-violet-600 transition-colors duration-200"
				>
					@shawnpapsmedia
				</a>
			</div>
		</section>
	</main>
</BaseLayout>
