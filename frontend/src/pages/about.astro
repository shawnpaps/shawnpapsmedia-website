---
import BaseLayout from "../layouts/BaseLayout.astro";

const services = [
	{
		label: "Web Development",
		items: [
			"Marketing sites and web apps",
			"CMS implementations",
			"E-commerce architecture",
			"API and platform integrations",
		],
	},
	{
		label: "Web Design",
		items: [
			"UX and interaction design",
			"Page and conversion design",
			"Design systems",
			"Prototype and handoff assets",
		],
	},
	{
		label: "Consulting + Creative Tech",
		items: [
			"Technical discovery and audits",
			"Architecture and roadmap planning",
			"AI-assisted workflow design",
			"Interactive product experiments",
		],
	},
];

const clients = [
	{
		type: "Small Teams",
		desc: "Lean teams that need senior-level development and design support without hiring a full internal team.",
	},
	{
		type: "Startups & Founders",
		desc: "Founders moving quickly who need product-minded execution across website, product UX, and engineering.",
	},
	{
		type: "Agencies",
		desc: "Creative and marketing agencies that need a technical partner to deliver custom web experiences for clients.",
	},
	{
		type: "Product Organizations",
		desc: "Product and ops teams that need help modernizing legacy systems or launching new internal tools.",
	},
];
---

<BaseLayout>
	<main class="flex flex-col min-h-screen px-20 py-16 gap-28">
		<!-- Hero -->
		<section
			class="flex flex-row items-center justify-between gap-16 w-full"
		>
			<div class="flex flex-col gap-6 max-w-2xl">
				<span
					class="text-xs font-medium text-violet-600 uppercase tracking-widest"
				>
					sudo create
				</span>
				<h1 class="text-6xl font-semibold text-gray-900 leading-tight">
					Small agency. Senior execution.
				</h1>
				<p class="text-xl font-light text-gray-500 leading-relaxed">
					sudo create is a focused web development agency that combines
					engineering, design, and consulting to help teams launch and
					improve high-impact digital products.
				</p>
				<p class="text-xl font-light text-gray-500 leading-relaxed">
					We stay intentionally small so clients get direct
					collaboration, fast decisions, and work that reflects the
					actual goals of the business.
				</p>
				<div class="flex flex-row items-center gap-4 mt-2">
					<a
						href="/contact"
						class="px-6 py-3 rounded-full bg-violet-600 text-white text-sm font-medium hover:bg-violet-700 transition-colors duration-200"
					>
						Start a project
					</a>
					<a
						href="/work"
						class="px-6 py-3 rounded-full border border-gray-200 text-gray-700 text-sm font-medium hover:border-violet-300 hover:text-violet-600 transition-colors duration-200"
					>
						View case studies
					</a>
				</div>
			</div>

			<div
				class="shrink-0 w-80 h-80 rounded-2xl overflow-hidden shadow-lg"
			>
				<img
					src={`${import.meta.env.PUBLIC_CMS_BASE ?? "http://localhost:3000"}/api/media/file/shawn_computer`}
					alt="sudo create"
					class="w-full h-full object-cover"
				/>
			</div>
		</section>

		<!-- The Edge -->
		<section
			class="flex flex-row items-start gap-20 border-t border-gray-100 pt-28"
		>
			<div class="max-w-sm shrink-0 flex flex-col gap-3">
				<span
					class="text-xs font-medium text-violet-600 uppercase tracking-widest"
				>
					The difference
				</span>
				<h2 class="text-4xl font-semibold text-gray-900 leading-tight">
					Built like a partner, not a vendor.
				</h2>
			</div>
			<div class="flex flex-col gap-6 max-w-xl pt-1">
				<p class="text-lg font-light text-gray-500 leading-relaxed">
					We combine technical depth with design thinking so product
					and marketing teams can move from idea to launch with fewer
					handoffs and less rework.
				</p>
				<p class="text-lg font-light text-gray-500 leading-relaxed">
					Our process is collaborative, practical, and focused on
					shipping work that performs in production.
				</p>
				<!-- Signature offer callout -->
				<div
					class="mt-4 p-6 rounded-2xl border border-violet-100 bg-violet-50"
				>
					<p
						class="text-xs font-semibold text-violet-600 uppercase tracking-widest mb-2"
					>
						How we work
					</p>
					<h3 class="text-xl font-semibold text-gray-900 mb-2">
						Discover -> Build -> Improve
					</h3>
					<p class="text-sm font-light text-gray-600 leading-relaxed">
						We define priorities, ship the right solution, and keep
						iterating with your team after launch.
					</p>
				</div>
			</div>
		</section>

		<!-- Services -->
		<section class="flex flex-col gap-10">
			<div class="flex flex-col gap-2">
				<span
					class="text-xs font-medium text-violet-600 uppercase tracking-widest"
				>
					Services
				</span>
				<h2 class="text-4xl font-semibold text-gray-900">What we do</h2>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				{
					services.map((group) => (
						<div class="flex flex-col gap-4 p-8 rounded-2xl border border-gray-100 bg-white/60 backdrop-blur-sm shadow-sm">
							<p class="text-xs font-semibold text-violet-600 uppercase tracking-widest">
								{group.label}
							</p>
							<ul class="flex flex-col gap-2">
								{group.items.map((item) => (
									<li class="flex items-center gap-2 text-gray-700 text-base font-light">
										<span class="w-1 h-1 rounded-full bg-violet-400 shrink-0" />
										{item}
									</li>
								))}
							</ul>
						</div>
					))
				}
			</div>
		</section>

		<!-- Who we serve -->
		<section class="flex flex-col gap-10">
			<div class="flex flex-col gap-2">
				<span
					class="text-xs font-medium text-violet-600 uppercase tracking-widest"
				>
					Who we work with
				</span>
				<h2 class="text-4xl font-semibold text-gray-900">
					Teams we work best with
				</h2>
			</div>

			<div class="flex flex-col">
				{
					clients.map((client, i) => (
						<div
							class={`flex flex-row gap-12 py-10 ${i !== clients.length - 1 ? "border-b border-gray-100" : ""}`}
						>
							<h3 class="text-lg font-semibold text-gray-900 w-48 shrink-0 pt-0.5">
								{client.type}
							</h3>
							<p class="text-base font-light text-gray-500 leading-relaxed max-w-xl">
								{client.desc}
							</p>
						</div>
					))
				}
			</div>

			<p class="text-base font-light text-gray-400 italic max-w-xl">
				Best fit: teams with clear goals, tight timelines, and a need
				for practical technical leadership.
			</p>
		</section>

		<!-- Location -->
		<section
			class="flex flex-row items-center gap-6 p-8 rounded-2xl border border-gray-100 bg-white/60 backdrop-blur-sm shadow-sm w-fit"
		>
			<div class="flex items-center gap-2">
				<div
					class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse shrink-0"
				>
				</div>
				<p class="text-sm font-medium text-gray-700">U.S.-based</p>
			</div>
			<div class="w-px h-4 bg-gray-200"></div>
			<p class="text-sm font-light text-gray-500">Remote-first</p>
			<div class="w-px h-4 bg-gray-200"></div>
			<p class="text-sm font-light text-gray-500">
				Available for project and retainer engagements
			</p>
		</section>

		<!-- CTA -->
		<section class="flex flex-col items-center text-center gap-6 py-20">
			<span
				class="text-xs font-medium text-violet-600 uppercase tracking-widest"
			>
				Ready to start?
			</span>
			<h2
				class="text-5xl font-semibold text-gray-900 max-w-xl leading-tight"
			>
				Let's scope your next build.
			</h2>
			<p
				class="text-xl font-light text-gray-500 max-w-lg leading-relaxed"
			>
				Share what you need to launch or improve, and we'll propose a
				clear plan to get it done.
			</p>
			<div class="flex flex-row items-center gap-4 mt-2">
				<a
					href="/contact"
					class="px-8 py-4 rounded-full bg-violet-600 text-white text-base font-medium hover:bg-violet-700 transition-colors duration-200"
				>
					Start now
				</a>
				<a
					href="/work"
					class="px-8 py-4 rounded-full border border-gray-200 text-gray-700 text-base font-medium hover:border-violet-300 hover:text-violet-600 transition-colors duration-200"
				>
					View work
				</a>
			</div>
		</section>
	</main>
</BaseLayout>
