---
import BaseLayout from "../layouts/BaseLayout.astro";

const services = [
	{
		label: "Photo",
		items: [
			"Brand & lifestyle photography",
			"Real estate & architecture",
			"Concert & music photography",
			"Event coverage & documentation",
		],
	},
	{
		label: "Video",
		items: [
			"Music videos & artist content",
			"Brand videos & promos",
			"Event videography",
			"Real estate walkthroughs",
		],
	},
	{
		label: "Web",
		items: [
			"Custom websites & landing pages",
			"CMS & e-commerce builds",
			"Brand identity & design",
			"Social & digital content",
		],
	},
];

const clients = [
	{
		type: "Barbers & Salons",
		desc: "Clean shots, fresh cuts, and a website that brings people through the door.",
	},
	{
		type: "Coffee Shops & Cafés",
		desc: "The vibe, the product, the space — captured right, built into a site that fits.",
	},
	{
		type: "Music Artists",
		desc: "Press shots, music videos, tour content, and a digital presence that matches the sound.",
	},
	{
		type: "Real Estate",
		desc: "Listing photography, walkthrough videos, and web presence that actually sells.",
	},
	{
		type: "Events & Launches",
		desc: "Fast, reliable photo and video coverage — delivered ready to post.",
	},
];
---

<BaseLayout>
	<main class="flex flex-col min-h-screen px-20 py-16 gap-28">
		<!-- Hero -->
		<section
			class="flex flex-row items-center justify-between gap-16 w-full"
		>
			<div class="flex flex-col gap-6 max-w-2xl">
				<span
					class="text-xs font-medium text-violet-600 uppercase tracking-widest"
				>
					Shawn Paps Media — Tampa, FL
				</span>
				<h1 class="text-6xl font-semibold text-gray-900 leading-tight">
					We make brands look like they mean it.
				</h1>
				<p class="text-xl font-light text-gray-500 leading-relaxed">
					Whether you're relaunching, rebranding, or just finally
					ready to look as serious as you are — we shoot it, edit it,
					and build the site it lives on.
				</p>
				<p class="text-xl font-light text-gray-500 leading-relaxed">
					Tampa-based, but we work with brands wherever the work takes
					us. One creative partner. Full-stack skillset. From the
					first frame to the last line of code.
				</p>
				<div class="flex flex-row items-center gap-4 mt-2">
					<a
						href="/contact"
						class="px-6 py-3 rounded-full bg-violet-600 text-white text-sm font-medium hover:bg-violet-700 transition-colors duration-200"
					>
						Let's talk
					</a>
					<a
						href="/work"
						class="px-6 py-3 rounded-full border border-gray-200 text-gray-700 text-sm font-medium hover:border-violet-300 hover:text-violet-600 transition-colors duration-200"
					>
						See the work
					</a>
				</div>
			</div>

			<div
				class="shrink-0 w-80 h-80 rounded-2xl overflow-hidden shadow-lg"
			>
				<img
					src={`${import.meta.env.PUBLIC_CMS_BASE ?? "http://localhost:3000"}/api/media/file/shawn_computer`}
					alt="Shawn Paps Media"
					class="w-full h-full object-cover"
				/>
			</div>
		</section>

		<!-- The Edge -->
		<section
			class="flex flex-row items-start gap-20 border-t border-gray-100 pt-28"
		>
			<div class="max-w-sm shrink-0 flex flex-col gap-3">
				<span
					class="text-xs font-medium text-violet-600 uppercase tracking-widest"
				>
					Why us
				</span>
				<h2 class="text-4xl font-semibold text-gray-900 leading-tight">
					One creative partner. Not three vendors.
				</h2>
			</div>
			<div class="flex flex-col gap-6 max-w-xl pt-1">
				<p class="text-lg font-light text-gray-500 leading-relaxed">
					Most brands hire a photographer, then a videographer, then a
					web developer — and wonder why nothing feels cohesive. We do
					all three. The photo, the video, and the site come from the
					same eye, the same aesthetic, the same point of view.
				</p>
				<p class="text-lg font-light text-gray-500 leading-relaxed">
					That means your brand photos are designed with your website
					in mind from day one. Your video content is cut for the
					platforms it'll live on. Everything works together because
					it was made together.
				</p>
				<!-- Signature offer callout -->
				<div
					class="mt-4 p-6 rounded-2xl border border-violet-100 bg-violet-50"
				>
					<p
						class="text-xs font-semibold text-violet-600 uppercase tracking-widest mb-2"
					>
						How we work
					</p>
					<h3 class="text-xl font-semibold text-gray-900 mb-2">
						Shoot → Edit → Build → Launch
					</h3>
					<p class="text-sm font-light text-gray-600 leading-relaxed">
						We take projects from creative direction through
						production, post-production, and web build. You deal
						with one person. Everything ships under one roof.
					</p>
				</div>
			</div>
		</section>

		<!-- Services -->
		<section class="flex flex-col gap-10">
			<div class="flex flex-col gap-2">
				<span
					class="text-xs font-medium text-violet-600 uppercase tracking-widest"
				>
					Services
				</span>
				<h2 class="text-4xl font-semibold text-gray-900">What we do.</h2>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				{
					services.map((group) => (
						<div class="flex flex-col gap-4 p-8 rounded-2xl border border-gray-100 bg-white/60 backdrop-blur-sm shadow-sm">
							<p class="text-xs font-semibold text-violet-600 uppercase tracking-widest">
								{group.label}
							</p>
							<ul class="flex flex-col gap-2">
								{group.items.map((item) => (
									<li class="flex items-center gap-2 text-gray-700 text-base font-light">
										<span class="w-1 h-1 rounded-full bg-violet-400 shrink-0" />
										{item}
									</li>
								))}
							</ul>
						</div>
					))
				}
			</div>
		</section>

		<!-- Who we serve -->
		<section class="flex flex-col gap-10">
			<div class="flex flex-col gap-2">
				<span
					class="text-xs font-medium text-violet-600 uppercase tracking-widest"
				>
					Who we work with
				</span>
				<h2 class="text-4xl font-semibold text-gray-900">
					Independent brands at an inflection point.
				</h2>
			</div>

			<div class="flex flex-col">
				{
					clients.map((client, i) => (
						<div
							class={`flex flex-row gap-12 py-10 ${i !== clients.length - 1 ? "border-b border-gray-100" : ""}`}
						>
							<h3 class="text-lg font-semibold text-gray-900 w-48 shrink-0 pt-0.5">
								{client.type}
							</h3>
							<p class="text-base font-light text-gray-500 leading-relaxed max-w-xl">
								{client.desc}
							</p>
						</div>
					))
				}
			</div>

			<p class="text-base font-light text-gray-400 italic max-w-xl">
				If you're relaunching, rebranding, or ready to finally look as
				serious as you are — that's who we work with.
			</p>
		</section>

		<!-- Location -->
		<section
			class="flex flex-row items-center gap-6 p-8 rounded-2xl border border-gray-100 bg-white/60 backdrop-blur-sm shadow-sm w-fit"
		>
			<div class="flex items-center gap-2">
				<div
					class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse shrink-0"
				>
				</div>
				<p class="text-sm font-medium text-gray-700">
					Based in Tampa, FL
				</p>
			</div>
			<div class="w-px h-4 bg-gray-200"></div>
			<p class="text-sm font-light text-gray-500">
				Tampa-based · works everywhere
			</p>
			<div class="w-px h-4 bg-gray-200"></div>
			<p class="text-sm font-light text-gray-500">
				Open to contract, freelance, and retainer work
			</p>
		</section>

		<!-- CTA -->
		<section class="flex flex-col items-center text-center gap-6 py-20">
			<span
				class="text-xs font-medium text-violet-600 uppercase tracking-widest"
			>
				Let's talk
			</span>
			<h2
				class="text-5xl font-semibold text-gray-900 max-w-xl leading-tight"
			>
				Ready to reintroduce your brand?
			</h2>
			<p
				class="text-xl font-light text-gray-500 max-w-lg leading-relaxed"
			>
				Tell us where you are and where you want to be. We'll handle
				the rest.
			</p>
			<div class="flex flex-row items-center gap-4 mt-2">
				<a
					href="/contact"
					class="px-8 py-4 rounded-full bg-violet-600 text-white text-base font-medium hover:bg-violet-700 transition-colors duration-200"
				>
					Start here
				</a>
				<a
					href="/work"
					class="px-8 py-4 rounded-full border border-gray-200 text-gray-700 text-base font-medium hover:border-violet-300 hover:text-violet-600 transition-colors duration-200"
				>
					See the work
				</a>
			</div>
		</section>
	</main>
</BaseLayout>
