---
import BaseLayout from "../layouts/BaseLayout.astro";
import MCPBot from "../components/react/mcp-bot.tsx";
import WorkShowcase from "../components/WorkShowcase.astro";
import BadgeContainer from "../components/BadgeContainer.astro";
import PhotoMarquee from "../components/PhotoMarquee.astro";
import ServicesPreview from "../components/react/ServicesPreview.tsx";

const CMS_BASE = import.meta.env.PUBLIC_CMS_BASE;
console.log("[index.astro] CMS_BASE =", CMS_BASE);

let marqueePhotos: {
	url: string;
	alt: string;
	width: number;
	height: number;
}[] = [];

interface WorkItem {
	title: string;
	client: string;
	summary: string;
	coverImage: string;
	slug: string;
}

let workItems: WorkItem[] = [];

try {
	const mediaRes = await fetch(`${CMS_BASE}/api/media?limit=100&depth=0`);
	const mediaData = await mediaRes.json();
	marqueePhotos = (mediaData?.docs ?? [])
		.filter((d: any) => d.mimeType?.startsWith("image/"))
		.map((d: any) => ({
			url: d.url,
			alt: d.alt ?? "",
			width: d.width,
			height: d.height,
		}));
	console.log("[index.astro] marqueePhotos fetched:", marqueePhotos.length);
} catch (e) {
	console.error("Failed to fetch media for marquee:", e);
}

try {
	const workRes = await fetch(
		`${CMS_BASE}/api/case-studies?limit=20&depth=1`,
	);
	const workData = await workRes.json();
	workItems = (workData?.docs ?? []).map((d: any) => ({
		title: d.title ?? "Untitled",
		client: d.client ?? "",
		summary: d.summary ?? "",
		coverImage: d.coverImage?.url
			? `${CMS_BASE}${d.coverImage.url}`
			: "https://placehold.co/288x192",
		slug: d.slug ?? d.id,
	}));
} catch (e) {
	console.error("Failed to fetch case studies:", e);
}

// Fallback work items if CMS fetch returns nothing
if (workItems.length === 0) {
	workItems = [
		{
			title: "Platform Redesign",
			client: "Growth Team",
			summary:
				"A modern marketing and product experience designed to improve clarity, speed, and conversion.",
			coverImage: "https://placehold.co/288x192",
			slug: "platform-redesign",
		},
		{
			title: "Internal Dashboard",
			client: "Operations Team",
			summary:
				"A custom web app that helps teams manage workflow, reporting, and day-to-day decision making.",
			coverImage: "https://placehold.co/288x192",
			slug: "internal-dashboard",
		},
		{
			title: "Design System Rollout",
			client: "Product Studio",
			summary:
				"A shared design language and component library to align product, design, and engineering teams.",
			coverImage: "https://placehold.co/288x192",
			slug: "design-system-rollout",
		},
		{
			title: "E-commerce Build",
			client: "Retail Brand",
			summary:
				"A conversion-focused storefront with custom integrations and a streamlined checkout flow.",
			coverImage: "https://placehold.co/288x192",
			slug: "ecommerce-build",
		},
		{
			title: "Creative Tech Prototype",
			client: "Innovation Team",
			summary:
				"An interactive prototype exploring how emerging technology can support real customer workflows.",
			coverImage: "https://placehold.co/288x192",
			slug: "creative-tech-prototype",
		},
	];
}
---

<BaseLayout>
	<main class="flex flex-col items-center min-h-screen">
		<!-- Hero -->
		<section
			class="flex flex-col lg:flex-row items-center lg:items-start justify-between gap-10 w-full px-6 sm:px-12 lg:px-20 pt-16 pb-20"
		>
			<div
				class="flex flex-col sm:flex-row items-center sm:items-start gap-8"
			>
				<div
					class="w-48 h-48 sm:w-64 sm:h-64 rounded-full overflow-hidden shrink-0"
				>
					<img
						class="w-full h-full object-cover"
						src={`${CMS_BASE}/api/media/file/shawn-camera`}
						alt="sudo create team"
						loading="eager"
					/>
				</div>
				<div class="max-w-lg text-center sm:text-left">
					<h1 class="text-5xl lg:text-6xl font-semibold">
						We build digital products that actually ship.
					</h1>
					<p class="text-xl lg:text-2xl font-light mt-4">
						sudo create is a small web dev agency specializing in web
						development, web design, software consulting, and creative
						technology.
					</p>
				</div>
			</div>
			<div class="flex flex-col items-center lg:items-end gap-4 shrink-0">
				<div
					class="p-2 flex flex-row items-center gap-2 bg-gray-100 rounded-full w-fit px-4 mb-2"
				>
					<div class="w-2 animate-pulse h-2 bg-red-600 rounded-full">
					</div>
					<p>Small agency, big builds</p>
				</div>
				<div
					id="badges"
					class="flex flex-wrap justify-center lg:justify-end gap-2"
				>
					<BadgeContainer />
				</div>
			</div>
		</section>

		<!-- MCP Bot section with marquee as background -->
		<section
			class="relative w-screen min-h-[40em] flex justify-center items-center"
		>
			<!-- Marquee background -->
			<div class="absolute inset-0 z-0">
				<PhotoMarquee photos={marqueePhotos} cmsBase={CMS_BASE} />
			</div>
			<!-- Overlay -->
			<div class="absolute inset-0 z-10 bg-white/30"></div>
			<!-- Content -->
			<div
				class="relative z-20 flex flex-col items-center gap-4 py-40 px-6 sm:px-20 justify-center bg-white/70 rounded-2xl w-fit mx-auto hover:bg-white transition-all ease-linear duration-200"
			>
				<h2 class="text-4xl font-medium text-center">
					Ask sudo create
				</h2>
				<p class="text-gray-600 text-base font-light">
					Ask about services, process, timelines, and project fit.
				</p>
				<MCPBot client:load />
			</div>
		</section>

		<!-- Services preview -->
		<section class="w-screen px-6 sm:px-20 py-20 border-t border-gray-100">
			<div class="flex flex-col gap-4 mb-10">
				<span
					class="text-xs font-medium text-violet-600 uppercase tracking-widest"
					>Services</span
				>
				<h2 class="text-4xl font-semibold text-gray-900">
					Web development, design, consulting, and creative technology.
				</h2>
			</div>
			<ServicesPreview
				cmsBase={CMS_BASE}
				allPhotos={marqueePhotos}
				client:load
			/>
		</section>

		<!-- Work showcase -->
		<section class="w-screen border-t border-gray-100 overflow-visible">
			<WorkShowcase items={workItems} />
		</section>

		<!-- Available for work CTA -->
		<section class="w-full px-6 sm:px-20 py-20 border-t border-gray-100">
			<div
				class="max-w-lg mx-auto text-center flex flex-col items-center gap-6"
			>
				<h2 class="text-4xl font-light">Need a technical partner?</h2>
				<p class="text-xl font-light text-gray-500">
					From discovery to launch, sudo create helps teams move faster
					with clear strategy and production-ready execution.
				</p>
				<a
					href="/contact"
					class="px-8 py-4 rounded-full bg-violet-600 hover:bg-violet-700 text-white text-sm font-medium transition-colors duration-200"
				>
					Start a project →
				</a>
			</div>
		</section>
	</main>
</BaseLayout>
