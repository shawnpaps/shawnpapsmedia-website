---
import BaseLayout from "../layouts/BaseLayout.astro";
import MCPBot from "../components/react/mcp-bot.tsx";
import WorkShowcase from "../components/WorkShowcase.astro";
import BadgeContainer from "../components/BadgeContainer.astro";
import PhotoMarquee from "../components/PhotoMarquee.astro";
import ServicesPreview from "../components/react/ServicesPreview.tsx";

const CMS_BASE = import.meta.env.PUBLIC_CMS_BASE?.replace(/\/$/, "");
const HERO_IMAGE_FILE = "Screenshot%202026-02-02%20at%201.37.00%20PM.jpg";
const heroImageSrc = CMS_BASE
	? `${CMS_BASE}/api/media/file/${HERO_IMAGE_FILE}`
	: "https://placehold.co/1600x900?text=Shawn+Paps+Media";
console.log("[index.astro] CMS_BASE =", CMS_BASE);

let marqueePhotos: {
	url: string;
	alt: string;
	width: number;
	height: number;
}[] = [];

interface WorkItem {
	title: string;
	client: string;
	summary: string;
	coverImage: string;
	slug: string;
}

let workItems: WorkItem[] = [];

if (CMS_BASE) {
	try {
		const mediaRes = await fetch(`${CMS_BASE}/api/media?limit=100&depth=0`);
		if (!mediaRes.ok)
			throw new Error(`Media fetch failed: ${mediaRes.status}`);
		const mediaData = await mediaRes.json();
		marqueePhotos = (mediaData?.docs ?? [])
			.filter((d: any) => d.mimeType?.startsWith("image/"))
			.map((d: any) => ({
				url: d.url,
				alt: d.alt ?? "",
				width: d.width,
				height: d.height,
			}));
		console.log(
			"[index.astro] marqueePhotos fetched:",
			marqueePhotos.length,
		);
	} catch (e) {
		console.error("Failed to fetch media for marquee:", e);
	}
}

if (CMS_BASE) {
	try {
		const workRes = await fetch(
			`${CMS_BASE}/api/case-studies?limit=20&depth=1`,
		);
		if (!workRes.ok)
			throw new Error(`Case studies fetch failed: ${workRes.status}`);
		const workData = await workRes.json();
		workItems = (workData?.docs ?? []).map((d: any) => ({
			title: d.title ?? "Untitled",
			client: d.client ?? "",
			summary: d.summary ?? "",
			coverImage: d.coverImage?.url
				? `${CMS_BASE}${d.coverImage.url}`
				: "https://placehold.co/288x192",
			slug: d.slug ?? d.id,
		}));
	} catch (e) {
		console.error("Failed to fetch case studies:", e);
	}
}

// Fallback work items if CMS fetch returns nothing
if (workItems.length === 0) {
	workItems = [
		{
			title: "Example Project One",
			client: "Client A",
			summary:
				"A brief overview of what this project involved, what problems were solved, and what was delivered.",
			coverImage: "https://placehold.co/288x192",
			slug: "example-project-one",
		},
		{
			title: "Example Project Two",
			client: "Client B",
			summary:
				"A brief overview of what this project involved, what problems were solved, and what was delivered.",
			coverImage: "https://placehold.co/288x192",
			slug: "example-project-two",
		},
		{
			title: "Example Project Three",
			client: "Client C",
			summary:
				"A brief overview of what this project involved, what problems were solved, and what was delivered.",
			coverImage: "https://placehold.co/288x192",
			slug: "example-project-three",
		},
		{
			title: "Example Project Four",
			client: "Client D",
			summary:
				"A brief overview of what this project involved, what problems were solved, and what was delivered.",
			coverImage: "https://placehold.co/288x192",
			slug: "example-project-four",
		},
		{
			title: "Example Project Five",
			client: "Client E",
			summary:
				"A brief overview of what this project involved, what problems were solved, and what was delivered.",
			coverImage: "https://placehold.co/288x192",
			slug: "example-project-five",
		},
	];
}
